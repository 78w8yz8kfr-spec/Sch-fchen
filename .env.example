COMPOSE_PROJECT_NAME=schaefchen
TZ=Europe/Berlin

POSTGRES_IMAGE=postgres:17-alpine
POSTGRES_DB=schaefchen
POSTGRES_USER=schaefchen
POSTGRES_PASSWORD=CHANGE_ME_POSTGRES_PASSWORD
POSTGRES_PORT=5432

NODE_ENV=development
API_DB_USER=schaefchen_api_login
API_DB_PASSWORD=CHANGE_ME_API_DB_PASSWORD
API_PORT=3000
API_ALLOWED_ORIGIN=http://localhost:4173
API_COOKIE_SECURE=false
API_DB_POOL_SIZE=10
SESSION_TTL_SECONDS=28800
APP_TIME_ZONE=Europe/Berlin

PGADMIN_IMAGE=dpage/pgadmin4:9
PGADMIN_DEFAULT_EMAIL=admin@example.invalid
PGADMIN_DEFAULT_PASSWORD=CHANGE_ME_PGADMIN_PASSWORD
PGADMIN_PORT=5050

MINIO_IMAGE=quay.io/minio/minio:RELEASE.2025-04-22T22-12-26Z
MINIO_ROOT_USER=schaefchen_admin
MINIO_ROOT_PASSWORD=CHANGE_ME_MINIO_PASSWORD
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

N8N_IMAGE=docker.n8n.io/n8nio/n8n:2
N8N_DB_NAME=n8n
N8N_ENCRYPTION_KEY=CHANGE_ME_N8N_ENCRYPTION_KEY_AT_LEAST_32_CHARACTERS
N8N_USER_MANAGEMENT_JWT_SECRET=CHANGE_ME_N8N_JWT_SECRET_AT_LEAST_32_CHARACTERS
N8N_PORT=5678
